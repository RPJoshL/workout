templ (i *Icons) BackArrow(className, title string, onClick templ.ComponentScript) {
	<svg xmlns="http://www.w3.org/2000/svg" class={className} viewBox="0 0 512 512" onClick={onClick}>
		<title>{title}</title>
		<path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="48" d="M244 400L100 256l144-144M120 256h292"/>
	</svg>
}

